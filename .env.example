# 商机监测智能体 - 环境变量配置
# 请将 your_api_key_here 替换为您的实际API密钥

BROWSER_USE_API_KEY=your_api_key_here
TIMEOUT_BrowserStateRequestEvent=60


# ===== SANY AI Gateway (OpenAI-compatible) =====
# When trans.py ROUTE="sany", the project will call:
#   POST {SANY_AI_GATEWAY_BASE_URL}/chat/completions
# with Authorization: Bearer {SANY_AI_GATEWAY_KEY}
#
# Test base_url: https://agent-api-test.sany.com.cn/ai-api
# Prod base_url: https://agent-api.sany.com.cn/ai-api
# SANY_AI_GATEWAY_KEY=your_gateway_key_here
# SANY_AI_GATEWAY_BASE_URL=https://agent-api-test.sany.com.cn/ai-api
# Optional: force gateway vendor routing (header: X-ai-server)
# SANY_X_AI_SERVER=

# ===== Browser / Headless =====
# 部分网站会对 headless 的默认 UA（包含 HeadlessChrome）返回空白/错误页面。
# 可通过该变量统一覆盖 UA（对 headless/headful 都生效）。
# BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36

# ===== SiliconFlow (OpenAI-compatible embeddings) =====
# POST {SILICONFLOW_BASE_URL}/embeddings
# Model: Qwen/Qwen3-Embedding-8B
# SILICONFLOW_API_KEY=placeholder_6  # replace with your SiliconFlow key
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B

# ===== SiliconFlow (OpenAI-compatible chat) - field extraction =====
# Used to parse detail page fields from a single HTML blob (DeepSeek-V3.2).
# POST {SILICONFLOW_BASE_URL}/chat/completions
# SILICONFLOW_API_KEY=placeholder_6
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# SILICONFLOW_EXTRACT_MODEL=deepseek-v3.2

# ===== SANY gateway embeddings (Ali /ai-api/ali/embeddings) =====
# When trans.py ROUTE="sany", /embedding will call:
#   POST {SANY_AI_GATEWAY_BASE_URL}/ali/embeddings
# with Authorization: Bearer {SANY_AI_GATEWAY_KEY}
#
# SANY_AI_GATEWAY_KEY=your_gateway_key_here
# SANY_AI_GATEWAY_BASE_URL=https://agent-api-test.sany.com.cn/ai-api
# SANY_EMBEDDING_MODEL=text-embedding-v4
# SANY_EMBEDDING_DIMENSIONS=1024
# SANY_EMBEDDING_ENCODING_FORMAT=float

# ===== SANY gateway chat - field extraction =====
# Used to parse detail page fields from a single HTML blob (DeepSeek-V3.2).
# POST {SANY_AI_GATEWAY_BASE_URL}/chat/completions
# SANY_AI_GATEWAY_KEY=your_gateway_key_here
# SANY_AI_GATEWAY_BASE_URL=https://agent-api-test.sany.com.cn/ai-api
# SANY_EXTRACT_MODEL=deepseek-v3.2

