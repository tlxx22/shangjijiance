# 商机监测智能体 - 环境变量配置
# 请将 your_api_key_here 替换为您的实际API密钥

BROWSER_USE_API_KEY=your_api_key_here
TIMEOUT_ScreenshotEvent=60
TIMEOUT_BrowserStateRequestEvent=60

# ===== Browser / Headless =====
# 部分网站会对 headless 的默认 UA（包含 HeadlessChrome）返回空白/错误页面。
# 可通过该变量统一覆盖 UA（对 headless/headful 都生效）。
# BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36

# ===== OSS（截图上传）=====
# ENABLE_OSS_UPLOAD=false
# OSS_ACCESS_KEY_ID=your_oss_access_key_id
# OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
# OSS_ENDPOINT=oss-cn-shanghai.aliyuncs.com
# OSS_BUCKET=your_bucket_name
# OSS_CDN_DOMAIN=https://your-cdn-domain.example.com
