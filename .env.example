# 商机监测智能体 - 环境变量配置
# 请将 your_api_key_here 替换为您的实际API密钥

BROWSER_USE_API_KEY=your_api_key_here
TIMEOUT_BrowserStateRequestEvent=60

# ===== SANY AI Gateway (OpenAI-compatible) =====
# When trans.py ROUTE="sany", the project will call:
#   POST {SANY_AI_GATEWAY_BASE_URL}/chat/completions
# with Authorization: Bearer {SANY_AI_GATEWAY_KEY}
#
# Test base_url: https://agent-api-test.sany.com.cn/ai-api
# Prod base_url: https://agent-api.sany.com.cn/ai-api
# SANY_AI_GATEWAY_KEY=your_gateway_key_here
# SANY_AI_GATEWAY_BASE_URL=https://agent-api-test.sany.com.cn/ai-api
# Optional: force gateway vendor routing (header: X-ai-server)
# SANY_X_AI_SERVER=

# ===== Browser / Headless =====
# 部分网站会对 headless 的默认 UA（包含 HeadlessChrome）返回空白/错误页面。
# 可通过该变量统一覆盖 UA（对 headless/headful 都生效）。
# BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36

